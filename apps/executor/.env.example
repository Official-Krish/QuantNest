# ──────────────────────────────────────────────
# QuantNest Executor — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Database ──────────────────────────────────
MONGO_URL=mongodb://localhost:27017/myapp

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis

# ── AI Model Provider ─────────────────────────
AI_MODEL_PROVIDER=gemini
GOOGLE_API_KEY=
GOOGLE_GENAI_MODEL=gemini-2.5-flash

# ── Notifications ─────────────────────────────
RESEND_API_KEY=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Rate Limits (requests per minute) ─────────
# Override defaults if needed
# RATE_LIMIT_ZERODHA=50
# RATE_LIMIT_GROWW=60
# RATE_LIMIT_LIGHTER=100
# RATE_LIMIT_GEMINI=60
# RATE_LIMIT_DISCORD=30
# RATE_LIMIT_SLACK=30
# RATE_LIMIT_TELEGRAM=20
# RATE_LIMIT_WHATSAPP=20
# RATE_LIMIT_GMAIL=10
# RATE_LIMIT_NOTION=30
# RATE_LIMIT_GOOGLE_DRIVE=30
# RATE_LIMIT_GOOGLE_SHEETS=30
# RATE_LIMIT_POSTGRES=200
# RATE_LIMIT_MARKET_DATA=100
# RATE_LIMIT_SOLANA=50

# ── Solana ─────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS_URL=
